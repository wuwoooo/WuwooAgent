<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textScreenInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#FF37474F" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="坐标为屏幕像素，原点在左上角。留空表示使用自动比例（见下方说明）。"
            android:textSize="12sp"
            android:textColor="#FF546E7A" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="聚焦输入框（点击聊天输入区域）"
            android:textStyle="bold"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/editInputX"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="input_x"
                android:inputType="numberDecimal|numberSigned"
                android:singleLine="true" />

            <EditText
                android:id="@+id/editInputY"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:hint="input_y"
                android:inputType="numberDecimal|numberSigned"
                android:singleLine="true" />
        </LinearLayout>

        <TextView
            android:id="@+id/textInputHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#FF78909C" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="点击发送（微信输入栏右侧发送按钮）"
            android:textStyle="bold"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/editSendX"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="send_x"
                android:inputType="numberDecimal|numberSigned"
                android:singleLine="true" />

            <EditText
                android:id="@+id/editSendY"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:hint="send_y"
                android:inputType="numberDecimal|numberSigned"
                android:singleLine="true" />
        </LinearLayout>

        <TextView
            android:id="@+id/textSendHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#FF78909C" />

        <Button
            android:id="@+id/btnSaveTapConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="保存" />

        <Button
            android:id="@+id/btnClearTapConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="清除自定义坐标（恢复自动比例）" />
    </LinearLayout>
</ScrollView>
