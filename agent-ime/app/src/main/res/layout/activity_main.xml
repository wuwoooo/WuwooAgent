<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/layoutLoginPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFFFF"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/textGuideTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Wuwoo Agent"
                android:textColor="#FF102027"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textGuideSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="请输入后台创建的 Agent 账号。登录成功后才能进入运行与权限设置。"
                android:textColor="#FF607D8B"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textLoginStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="#FFFFF8E1"
                android:padding="12dp"
                android:text="Agent 账号：未登录"
                android:textColor="#FF795548"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/inputAgentUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Agent 用户名"
                android:singleLine="true" />

            <EditText
                android:id="@+id/inputAgentPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Agent 密码"
                android:inputType="textPassword"
                android:singleLine="true" />

            <LinearLayout
                android:id="@+id/layoutNetworkConfig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/inputAgentEndpoint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="后端接口地址（通常无需修改）"
                    android:inputType="textUri"
                    android:singleLine="true" />
            </LinearLayout>

            <Button
                android:id="@+id/btnAgentLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="登录 Agent 账号" />

            <TextView
                android:id="@+id/textToggleNetworkConfig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:padding="8dp"
                android:text="显示网络配置"
                android:textColor="#FF3F51B5"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutMainContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/textAgentAuthStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#FFF1F8E9"
                android:padding="12dp"
                android:text="Agent 账号：已登录"
                android:textColor="#FF1B5E20"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnAgentLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="退出当前 Agent 账号" />

        <TextView
            android:id="@+id/textCurrentStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#FFF1F8E9"
            android:padding="12dp"
            android:textColor="#FF1B5E20"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textAccessibilityStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#FFF5F5F5"
            android:padding="10dp"
            android:textColor="#FF37474F"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textImeStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#FFF5F5F5"
            android:padding="10dp"
            android:textColor="#FF37474F"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textNotificationStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#FFF5F5F5"
            android:padding="10dp"
            android:textColor="#FF37474F"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textForegroundAutoStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#FFF5F5F5"
            android:padding="10dp"
            android:textColor="#FF37474F"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textCaptureProvider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#FF37474F"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textExecutionMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#FF37474F"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textBackendStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#FF37474F"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnGrantProjection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="去授权截图" />

        <Button
            android:id="@+id/btnAccessibilitySettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="去打开无障碍设置" />

        <Button
            android:id="@+id/btnImeSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="去打开输入法设置" />

        <Button
            android:id="@+id/btnNotificationSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="去打开通知读取权限" />

        <Button
            android:id="@+id/btnToggleNotificationAuto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="开启/关闭后台通知自动触发" />

        <Button
            android:id="@+id/btnToggleForegroundAuto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="开启/关闭前台聊天自动触发" />

        <Button
            android:id="@+id/btnStartRunOnce"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="开始运行" />

        <TextView
            android:id="@+id/textSupportTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="辅助与高级"
            android:textColor="#FF102027"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnToggleAdvanced"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="展开高级选项" />

        <LinearLayout
            android:id="@+id/layoutAdvanced"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/inputSessionId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="session_id（可选）"
                android:singleLine="true" />

            <EditText
                android:id="@+id/inputContactName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="contact_name（可选）"
                android:singleLine="true" />

            <TextView
                android:id="@+id/textAdvancedHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="session/contact 一般可留空；后端接口地址在登录页配置，通常不需要改。"
                android:textColor="#FF607D8B"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnModeAuto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="切到自动模式（调试用）" />

            <Button
                android:id="@+id/btnModeManual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="切到手动模式（调试用）" />

            <Button
                android:id="@+id/btnDebugRunOnce"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="立即执行一次 runOnce（调试）" />

            <Button
                android:id="@+id/btnTapConfig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="配置点击坐标（输入框 / 发送）" />

            <Button
                android:id="@+id/btnOverlaySettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="打开应用详情（权限排查）" />

            <TextView
                android:id="@+id/textLogTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="日志与诊断"
                android:textColor="#FF102027"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnRefreshLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="刷新日志" />

            <Button
                android:id="@+id/btnCopyLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="复制日志" />

            <Button
                android:id="@+id/btnClearLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="清除日志" />

            <TextView
                android:id="@+id/textLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="#FF263238"
                android:textSize="12sp"
                android:textIsSelectable="true" />
        </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/textCopyright"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="wuwoo 版权所有"
            android:textColor="#FF90A4AE"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
