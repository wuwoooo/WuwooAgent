# 选择后端 Provider：
# - volc_knowledge：火山知识库检索 + 火山模型生成（默认）
# - adp：腾讯云 ADP 智能体
CHAT_PROVIDER=volc_knowledge

# 火山知识库配置
VOLCENGINE_AK=your_volc_ak
VOLCENGINE_SK=your_volc_sk
VOLCENGINE_ACCOUNT_ID=your_account_id
VOLCENGINE_KNOWLEDGE_DOMAIN=api-knowledgebase.mlp.cn-beijing.volces.com
VOLCENGINE_KNOWLEDGE_SCHEMA=https
VOLCENGINE_PROJECT_NAME=default
VOLCENGINE_COLLECTION_NAME=travle_YN
VOLCENGINE_MODEL=Deepseek-v3
VOLCENGINE_MODEL_VERSION=250324
VOLCENGINE_TEMPERATURE=0.7
VOLCENGINE_MAX_TOKENS=1024
VOLCENGINE_SEARCH_LIMIT=8

# 腾讯云 ADP（可选回退）
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
TENCENT_REGION=ap-guangzhou
TENCENT_ADP_APP_KEY=your_tencent_adp_app_key

# HTTP Basic Auth Dashboard Login
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# 火山引擎 Ark (豆包) API 配置 (用于画像提取)
VOLC_ARK_API_KEY=your_ark_api_key_here
VOLC_ARK_MODEL=doubao-seed-2-0-mini-260215

# VLM 视觉提取配置 (用于微信截图 OCR)
ARK_VISION_API_KEY=your_ark_vision_api_key_here
ARK_VISION_MODEL_ID=doubao-seed-2-0-mini-260215
